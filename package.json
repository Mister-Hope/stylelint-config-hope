{
  "name": "stylelint-config-hope",
  "version": "11.0.0",
  "description": "Shareable config for Stylelint",
  "keywords": [
    "stylelint",
    "stylelint-config"
  ],
  "homepage": "https://github.com/Mister-Hope/stylelint-config-hope",
  "bugs": {
    "url": "https://github.com/Mister-Hope/stylelint-config-hope/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mister-Hope/stylelint-config-hope.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint --fix --report-unused-disable-directives --deny-warnings && oxfmt",
    "lint:check": "oxlint --report-unused-disable-directives --deny-warnings && oxfmt --check",
    "prepare": "husky",
    "prepublish": "pnpm run build",
    "test": "stylelint tests/**/*.scss"
  },
  "dependencies": {
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.3",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.1.6",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "stylelint": "17.6.0",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "stylelint": "^17.0.0"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "packageManager": "pnpm@10.33.0"
}
